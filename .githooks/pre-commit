#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
echo "Running build before commit..."
bash "$SCRIPT_DIR/scripts/build.sh"

cd "$SCRIPT_DIR" || exit 1

echo "Running lint before commit..."
npm run lint
if [ $? -ne 0 ]; then
  echo "Lint failed. Commit aborted."
  exit 1
fi

if [ ! -d "node_modules/@playwright/test" ]; then
  echo "Playwright not installed. Running npm install..."
  npm install || { echo "npm install failed. Commit aborted."; exit 1; }
fi

echo "Running Playwright lint specs before commit..."
npx playwright test --config=config/playwright.config.js --project=lint
if [ $? -ne 0 ]; then
  echo "Playwright lint specs failed. Commit aborted."
  exit 1
fi
