#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
echo "Running build before commit..."
bash "$SCRIPT_DIR/scripts/build.sh"

cd "$SCRIPT_DIR" || exit 1

if [ ! -d "node_modules/@playwright/test" ]; then
  echo "Playwright not installed. Running npm install..."
  npm install || { echo "npm install failed. Commit aborted."; exit 1; }
fi

echo "Running tests before commit..."
# --retries=1 retries each failed test once before marking it failed, to
# absorb parallel-worker flakes (page/context closed under CPU contention)
# that occasionally hit the heavier e2e specs.
npx playwright test --config=config/playwright.config.js --retries=1
if [ $? -ne 0 ]; then
  echo "Tests failed. Commit aborted."
  exit 1
fi
