{
  "name": "ghost-in-msheet",
  "version": "1.0.0",
  "description": "An attempt at continuing Trykowka's 'The Ghost Hunter', now as Ghost in M'Sheet",
  "main": "index.html",
  "scripts": {
    "build": "node -e \"require('child_process').execSync(process.platform==='win32'?'build.bat':'./build.sh',{stdio:'inherit'})\"",
    "start": "node -e \"require('child_process').execSync(process.platform==='win32'?'start.bat':'./start.sh',{stdio:'inherit'})\"",
    "setup": "node -e \"require('child_process').execSync(process.platform==='win32'?'setup.bat':'./setup.sh',{stdio:'inherit'})\"",
    "watch": "while inotifywait -e modify -e create -e delete passages/*.tw; do ./build.sh; done",
    "clean": "node -e \"try{require('fs').unlinkSync('ghost-in-msheet.html')}catch(e){}\"",
    "rebuild": "npm run clean && npm run build",
    "pretest": "npm run build",
    "test": "npx playwright test",
    "prepare": "git config core.hooksPath .githooks"
  },
  "keywords": [
    "twine",
    "twee",
    "story",
    "game"
  ],
  "author": "",
  "license": "GPLv3",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "serve": "^14.0.0"
  }
}
