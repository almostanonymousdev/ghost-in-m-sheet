<span class="priceAmount">200$</span><br>
<<if $mc.money gte 200>>
@@.buyItemLink;<<link "Buy" "witchSale">>
<<set $boughtDetector to 1>>
<<set $mc.money -= 200>>
<</link>>@@<br>
<<else>>@@.mc-thoughts; I don't have enough money@@<</if>>
<</if>>
</div>
