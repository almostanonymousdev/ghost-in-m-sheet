@@.buyItemLink;<<link "Buy (lvl 2)" "witchSale">>
<<set $equipment.temperature to 4>>
<<set $mc.money -= 100>>
<</link>>@@<br>
<<else>>@@.mc-thoughts; I don't have enough money@@<</if>>
<</if>>
</div>
