  max-width: 100%;
}

.addGap5 {
	gap: 5%;
}

.hauntedhouse {
  	background-attachment: fixed;
	overflow: hidden;
  	height: 100vh;
  	background-position: center;
}

.noreturn {
	background-attachment: fixed;
}

.highlighted-furniture {
    border: 2px solid pink; 
}

.fadeInScale {
    opacity: 0;
    transform: scale(0.8);
    transition: opacity 3s ease, transform 1s ease;
}
.fadeInScaleFool {
	opacity: 0;
    transition: opacity 1s ease;
}
.tarotCardsShow {
    opacity: 1;
    transform: scale(1);
}

.smooth-transition {
    transition: background-image 0.9s ease;
}

.hideMainScreen {
	color: rgba(255, 255, 255, 0.8);
}

.debug {
	font-size: 0.8em;
	font-weight: bold;
}

