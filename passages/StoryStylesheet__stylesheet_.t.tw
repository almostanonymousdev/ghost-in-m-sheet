.right {
  	display: inline-block;
	background-color: green;
  	border-radius: 30%;
}

.room {
   	position: absolute;
    top: 0;
  	height: 100vh;
	overflow-x: hidden;
	display: flex;
}
.room-wrapper {
    line-height: 1;
  	width: 100%;
  	display: flex;
  	position: relative;
  	flex-direction: column;
  	box-sizing: border-box;
 	padding-bottom: 5%;
}

.content {
	height: calc(100%/1.25);
    max-width: 80%;
  	overflow: hidden;
    box-sizing: border-box;
  	padding: 0;
}

.footer {
	display:flex;
  	align-items: flex-end;
  	max-height: 20%;
}

.footer-card {
	display: flex;
    flex-wrap: wrap;
    flex-direction: column;
	width: calc(100% / 7);
}

.footertools {
	display:flex;
  	width: 80%;
  	align-items: center;

}

.footeraction {
  	line-height: 1.6;
  	width: 20%;
	display: flex;
    flex-direction: column;
}

.cardlink {
	line-height: 1;
  	height: 30px;
  	font-size: 80%;
}

.hidden {
	visibility: hidden;
}

.visible {
	visibility: visible;
}

.UVLimg {
  	max-width: 100%;
    height: auto; 
  	display: block;
}

.action {
	display:flex;
  	flex-direction: column;
  	 align-items: center;
}

.GWBimgs {
	max-width: 50%;
}

.mc-action {
        background-color: #ffe6f2; 
        padding: 10px; 
        border-radius: 10px; 
        border: 2px solid #ff66b2; 
        font-family: 'Arial', sans-serif; 
        font-size: 18px; 
        color: #99004d; 
        text-align: center; 
    }

.spiritbox-container { 
    padding: 10px;
    border-radius: 10px;
    border: 2px solid #333; 
    margin-bottom: 10px;
    display: flex;
    flex-direction: column;
  	font-weight: bold;
}

.spiritbox-question {
    font-weight: bold;
    color: #ff3366; 
}

.spiritbox-answer {
    font-style: italic;
    color: #3399ff; 
    margin-top: 5px;
}

.spiritbox-no-response {
    color: white; 
    font-style: italic;
}

.location {
	font-size: 1.5em;
  	font-style: italic;
  	color: #f2f5f7;
  	text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
}

.mc-speech {
	color:#ff99dd;
  	text-decoration: none;
  	  text-shadow:-1px -1px 0 #000,  1px -1px 0 #000,-1px  1px 0 #000,1px  1px 0 #000;
}

.mc-speech:hover {
	
  	text-decoration: none;
  	text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.5);
}

.mc-speech a {
	color:#FF1493;
  	font-style: italic;
  	text-decoration: none;
}

.mc-speech a:hover {
	color:#f663b2;
  	font-style: italic;
  	text-decoration: none;
  	text-shadow: 2px 2px 5px rgba(0, 0, 0, 0.5);
}


.mc-speechLink a {
	color:#FF1493;
  	font-style: italic;
  	text-decoration: none;
}

.mc-speechLink {
	color:#FF1493;
  	font-style: italic;
  	text-decoration: none;
}

.mc-thoughts {
  color: #eee;
  font-style: italic;
  text-decoration: none;
  text-shadow:-1px -1px 0 #000,  1px -1px 0 #000,-1px  1px 0 #000,1px  1px 0 #000;
  
}

.mc-thoughts a {
  color: #777777;
  font-style: italic;
  text-decoration: none;
}

.mc-thoughtsLink {
  color: #777777;
  font-style: italic;
  text-decoration: none;
}

