#bgPC {
  display: block;
  width: 100%;
  height: auto;
}

.iconContainer {
  position: absolute;
  top: 25%;
  left: 30%;
  transform: translate(-30%, -25%);
  width: calc(100% - 40px); 
  height: calc(100% - 40px); 
  display: flex;
  flex-wrap: wrap; 
  gap: 10px;
  box-sizing: border-box;
  padding: 20px;
  justify-content: flex-start; 
  align-items: flex-start;
}

.iconContainer a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: calc(20% - 10px);
  max-width: 100px; 
  height: auto; 
}

.iconContainer img {
  width: 100%; 
  height: auto; 
  max-width: 100%; 
  max-height: 100%; 
  display: block;
  border-radius:50%;
}

.wrapperPC {
  position: relative;
  width: 100%;
  max-width: 1000px;
  overflow: hidden; 
}

.iconPC {
  border-radius:50%;
  margin-bottom: 1%; 
}

 .room-container {
    position: relative;
   	padding-bottom: 66.67%;
    width: 100%;
    background-image: url('assets/img/hotelRoom.jpeg');
    background-size: cover;
   	background-position: center;
   	overflow: hidden;
  }
  .trash {
    position: absolute;
    cursor: pointer;
    width: 5%;
    height: auto;
  }
  #cleanup-message {
    display: none;
    margin-top: 20px;
    font-weight: bold;
