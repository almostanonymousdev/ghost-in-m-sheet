:: CheckHuntStart [noreturn nobr] {"position":"2500,1100","size":"100,100"}
<<if setup.HauntedHouses.canStartRandomHunt()>>
	<<if random(0, 100) lte 6>>
		<<set _g = setup.Ghosts.getByName($ghost.name)>>
		<<if setup.Ghosts.huntConditionMet(_g, $mc)>>
			<<goto "GhostHuntEvent">>
		<</if>>
	<</if>>
<</if>>
