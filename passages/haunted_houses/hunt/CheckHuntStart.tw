:: CheckHuntStart [noreturn nobr] {"position":"2500,1100","size":"100,100"}
<<if setup.HauntedHouses.canStartRandomHunt()>>
	<<set _huntThreshold to 6 + setup.HauntConditions.snapshot().huntChanceBonus>>
	<<if random(0, 100) lte _huntThreshold>>
		<<set _g to setup.Ghosts.active()>>
		<<if _g and _g.canHunt(setup.Mc.mc())>>
			<<goto "GhostHuntEvent">>
		<</if>>
	<</if>>
<</if>>
