:: stealClothesEvent [nobr] {"position":"4025,950","size":"100,100"}
<<set _chanceToSteal to random(1,100)>>
<<if _chanceToSteal lte $stealChance >>
<<if $braState eq "worn" or $pantiesState eq "worn" or ($jeansState eq "worn" or $skirtState eq "worn" or $shortsState eq "worn")>>
<<set _stealClothesTriggered = true>>
<<goto "stealClothes">><</if>>
<</if>>


