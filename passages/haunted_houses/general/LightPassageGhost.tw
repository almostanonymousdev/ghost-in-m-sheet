:: LightPassageGhost [nobr] {"position":"1700,1500","size":"100,100"}
<<if setup.Ghosts.active() and setup.Ghosts.active().canTurnOffLights>>
	<<if random(1,65) eq 1>>
		<<run setup.activateTool("emf")>>
		<<set _darkened to setup.Events.turnOffLightHere()>>
		<<if _darkened>>
			<<goto _darkened>>
		<</if>>
	<</if>>
<</if>>
