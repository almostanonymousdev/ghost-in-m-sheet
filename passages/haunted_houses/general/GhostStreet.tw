:: GhostStreet [ghoststreet] {"position":"1950,350","size":"100,100"}
<div class="flexwrapper">
<div class="housecard">
<<image "img/owaissa-house.jpg" "iconPx">>
<<nobr>>
@@.icontext;<<link "Owaissa Street" "Owaissa Street">>
<<if $deleteThirdEvidence eq 1>>
<<set $moneyFromContract to 450>>
<<set $expFromContract to 140>>
<<elseif $deleteSecondEvidence eq 1>>
<<set $moneyFromContract to 340>>
<<set $expFromContract to 100>>
<<elseif $deleteOneEvidence eq 1>>
<<set $moneyFromContract to 240>>
<<set $expFromContract to 70>>
<<else>>
<<set $moneyFromContract to 120>>
<<set $expFromContract to 35>>
<</if>>
<<set $isrealhouse to 0>><<set $isOwaissa to 1>>
<<include "FurnitureCode">>
<<set _check to random (1,5)>>
<<if _check eq 1>><<set $hunt.room to clone($kitchen)>><</if>>
<<if _check eq 2>><<set $hunt.room to clone($bathroom)>><</if>>
<<if _check eq 3>><<set $hunt.room to clone($bedroom)>><</if>>
<<if _check eq 4>><<set $hunt.room to clone($livingroom)>><</if>>
<<if _check eq 5>><<set $hunt.room to clone($hallway)>><</if>>
<</link>>@@
<</nobr>>
</div>
<div class="housecard">

</div>
<div class="housecard">
</div>
<div class="housecard">
<<image "room/ironclad/ironclad.webp" "iconPx">>
<<nobr>>
<<if $mc.lvl gte 4>>@@.icontext;<<link "Prison Ironclad" "Ironclad Prison">>
<<if $deleteThirdEvidence eq 1>>
<<set $moneyFromContract to 650>>
<<set $expFromContract to 240>>
<<elseif $deleteSecondEvidence eq 1>>
<<set $moneyFromContract to 440>>
<<set $expFromContract to 150>>
<<elseif $deleteOneEvidence eq 1>>
<<set $moneyFromContract to 240>>
<<set $expFromContract to 100>>
<<else>>
<<set $moneyFromContract to 170>>
<<set $expFromContract to 60>>
<</if>>
<<set $isrealhouse to 0>>
<<set $isIronclad to 1>>
<<include "FurnitureCode">>
<<set _check to random (1,11)>>
<<if _check eq 1>><<set $hunt.room to clone($BlockA)>><</if>>
<<if _check eq 2>><<set $hunt.room to clone($BlockB)>><</if>>
<<if _check eq 3>><<set $hunt.room to clone($BlockACellA)>><</if>>
<<if _check eq 4>><<set $hunt.room to clone($BlockACellB)>><</if>>
<<if _check eq 5>><<set $hunt.room to clone($BlockACellC)>><</if>>
<<if _check eq 6>><<set $hunt.room to clone($BlockBCellA)>><</if>>
<<if _check eq 7>><<set $hunt.room to clone($BlockBCellB)>><</if>>
<<if _check eq 8>><<set $hunt.room to clone($BlockBCellC)>><</if>>
<<if _check eq 9>><<set $hunt.room to clone($reception)>><</if>>
<<if _check eq 10>><<set $hunt.room to clone($kitchen)>><</if>>
<<if _check eq 11>><<set $hunt.room to clone($hallway)>><</if>>
<</link>>@@
<<else>>@@.mc-thoughts; Level 4+ required@@
<</if>>
<</nobr>>
</div>
<div class="housecard">

</div>
<div class="housecard">

</div>
<div class="housecard">
<<image "img/elm-house.jpg" "iconPx">>
