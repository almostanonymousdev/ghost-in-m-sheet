(function() {
    if (State.variables.cursedHuntActive === 1) {
   
        let duration = 20;
        let interval = 1;
        let lightCycle = 0;
        let endTime = Date.now() + duration * 1000;
        function toggleLights() {
            let isDark = lightCycle % 2 === 0;
			if (State.variables.isOwaissa === 1) {
