                $('body.elmbedroom').addClass('smooth-transition elmBedroomDark').removeClass('elmBedroomLight');
                $('body.elmbedroomtwo').addClass('smooth-transition elmBedroomTwoDark').removeClass('elmBedroomTwoLight');
                $('body.elmbasement').addClass('smooth-transition elmBasementDark').removeClass('elmBasementLight');
                $('body.elmnursery').addClass('smooth-transition elmNurseryDark').removeClass('elmNurseryLight');
            } else {
                $('body.elmkitchen').addClass('smooth-transition elmKitchenLight').removeClass('elmKitchenDark');
                $('body.elmhallway').addClass('smooth-transition elmHallwayLight').removeClass('elmHallwayDark');
                $('body.elmhallwayupstairs').addClass('smooth-transition elmHallwayTwoLight').removeClass('elmHallwayTwoDark');
                $('body.elmbathroom').addClass('smooth-transition elmBathroomLight').removeClass('elmBathroomDark');
                $('body.elmbathroomtwo').addClass('smooth-transition elmBathroomTwoLight').removeClass('elmBathroomTwoDark');
                $('body.elmbedroom').addClass('smooth-transition elmBedroomLight').removeClass('elmBedroomDark');
                $('body.elmbedroomtwo').addClass('smooth-transition elmBedroomTwoLight').removeClass('elmBedroomTwoDark');
                $('body.elmbasement').addClass('smooth-transition elmBasementLight').removeClass('elmBasementDark');
                $('body.elmnursery').addClass('smooth-transition elmNurseryLight').removeClass('elmNurseryDark');
            }
			}
            lightCycle++;

            if (Date.now() < endTime) {
                setTimeout(toggleLights, interval * 1000);
            } else {
                  $('.cursedHuntLinkDisable').removeClass('disabled-linkSpecial');
if (State.variables.ghost.name === "Deogen") {
    if (State.variables.isInHideSpot === 1 && State.variables.cursedHuntActive === 1) {
