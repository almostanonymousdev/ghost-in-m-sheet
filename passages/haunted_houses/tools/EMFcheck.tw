:: EMFcheck [nobr] {"position":"3725,225","size":"100,100"}
<<set _state to setup.tickTimedTool("emf")>>
<<set _hg to setup.Ghosts.active()>>
<<if _state eq "ready" and _hg and _hg.hasEvidence("emf")>>
	<<if _hg.rollEmfGlitch()>>
		<<coloredText "red" `random(0, 100)`>>
	<<else>>
		<<coloredText "red" 5>>
	<</if>>
<<elseif _state eq "ready">>
	<<coloredText "yellow" `random(1, 4)`>>
<<else>>
	<<coloredText "green" 0>>
<</if>>
