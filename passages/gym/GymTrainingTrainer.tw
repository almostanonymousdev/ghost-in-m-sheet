:: GymTrainingTrainer [nobr] {"position":"2950,1325","size":"100,100"}
<<set $mc.money -= $trainingCost>>
<<addTime 60>>
<<include "GymTrainer">>

<<gymFitnessGain 2>>
<<if not setup.CursedGym.isBagStolen()>>
	<<run setup.CursedGym.rollForGymBagSwap()>>
<</if>>
<br>
<br>
@@.backbtn;[[Back|GymInside]] @@
<<done>>
	<<addclass ".linkselector" "disabled-link">>
<</done>>
