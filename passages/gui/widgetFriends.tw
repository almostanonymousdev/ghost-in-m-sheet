		@@.mc-speech; $companion.name, are you okay?@@<br>
		@@.notmc-speech; Oh~ he touched me, and I... I don't understand what was happening to me.@@<br>
		<<set $transFirstStage to 1>>
		<<if $companion.name eq "Alex">>
			<<set $transPicture to 1>>
		<<elseif $companion.name eq "Taylor">>
			<<set $transPicture to 2>>
		<<elseif $companion.name eq "Casey">>
			<<set $transPicture to 3>>
		<</if>>
	<</if>>
	<<set $companion.sanity -= $companion.decreaseSanity>>
	<<set $companion.lust += _companionLustIncreased>>
	$companion.name's lust: + _companionLustIncreased <img @src="setup.ImagePath + '/img/hearth.png'" style="position: relative; top: 0.375em; width:3%;"><br>
	$companion.name's sanity: - $companion.decreaseSanity<img @src="setup.ImagePath + '/img/sanity.png'" style="position: relative; top: 0.375em; width:3%;"><br>
	Your <img @src="setup.ImagePath + '/img/hearth.png'" style="position: relative; top: 0.375em; width:3%;"> +15<br>
	<<addLust 15>>
<</widget>>

