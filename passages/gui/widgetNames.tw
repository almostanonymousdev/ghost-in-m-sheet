:: widgetNames [widget nobr] {"position":"300,1600","size":"100,100"}
<<widget "ghostRoom">>
	<<set _roomLabel to setup.Ghosts.huntRoomName()>>
	<<if _roomLabel eq "">>
		<<set _roomLabel to setup.HuntController.ghostRoomLabel()>>
	<</if>>
	<<if _roomLabel neq "">>
		<b><<= _roomLabel.toLowerCase()>></b>
	<</if>>
<</widget>>
