:: widgetSpecialEvent [widget nobr] {"position":"950,2350","size":"100,100"}
/* Special events use randomVideo widget defined in church for random video selection */

<<widget "randomVideoFromList">>
<<set _rvList to _args[0]>>
<<set _rvIdx to random(0, _rvList.length - 1)>>
<<set _rvSelected to _rvList[_rvIdx]>>
<video autoplay controls muted loop>
<source @src="setup.ImagePath + '/' + _rvSelected" type="video/mp4">
</video>
<</widget>>
