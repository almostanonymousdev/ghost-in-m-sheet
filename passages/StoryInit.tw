evidence: [$EvidenceType.GLASS, $EvidenceType.GWB, $EvidenceType.SPIRITBOX],
}>>

<<set $ghost8 to {
name: "Jinn",
evidence: [$EvidenceType.EMF, $EvidenceType.UVL, $EvidenceType.TEMPERATURE],
