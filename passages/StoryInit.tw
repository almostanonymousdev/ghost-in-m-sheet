----------------------------------------------------------------------------------------

----------

<<run ["kitchen", "bathroom", "bedroom", "hallway", "livingroom"].forEach(function(name) {
	State.variables[name] = {
		name: name,
		emf: "", glass: "", uvl: "", temperature: "", spiritbox: "", gwb: "",
		background: 2
	};
})>>

<<newmeter 'energy'>>
    <<sizing '220px'>>
    <<colors #d8f22c>>
    <<label '$mc.energy'>>
<</newmeter>>

<<newmeter 'sanity'>>
    <<sizing '220px'>>
    <<label '$mc.sanityUp'>>
 <</newmeter>>
 ------------------------------------------------------------
 /*Tools meters (one per room × tool)*/
<<for _room range ["Kitchen", "Hallway", "Bathroom", "Livingroom", "Bedroom"]>>
<<for _tool range ["Emf", "Plasm", "Uvl", "Temperature", "Gwb", "Spiritbox"]>>
<<newmeter `"search" + _room + _tool`>>
<<sizing '50%'>>
<<label `"$currentsearch" + _room + "." + _tool.toLowerCase()`>>
<</newmeter>>
<</for>>
<</for>>

<<newmeter 'xpBar' $mc.exp>>
    <<label '$percentageOfLevel %'>>
    <<colors 'green'>>
    <<sizing '50%' 20px>>
    <<animation 2s swing>>
<</newmeter>>
