<<widget "includeStyleEventMC">>
	<<if previous() is "FurnitureSearch" and setup.Events.isDarkRoom(previous(2))>>
		<style>
        .eventVideo-container {
            position: relative;
            overflow: hidden;
        }
        #eventVideo {
           filter: brightness(0.8) contrast(1.1) grayscale(0.95);
        }
    </style>
