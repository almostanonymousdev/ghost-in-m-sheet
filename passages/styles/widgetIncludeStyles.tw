:: widgetIncludeStyles [widget nobr] {"position":"300,1900","size":"100,100"}

<<widget "includeStyle">>
	<style>
  	body {
  	height: 100vh;
  	background-position: center;

}
</style>
	<<if previous() is "OwaissaHallway">>
