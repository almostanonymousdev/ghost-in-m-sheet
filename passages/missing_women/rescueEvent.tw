:: rescueEvent [nobr] {"position":"2175,1800","size":"100,100"}
<<if $rescueStage eq 0>>
<<include "rescueSuccess">>
<<elseif $rescueStage eq 1 and $hours lt 18>>
    <<set _chanceSuccess to 100 - ($hours * 100 / 18)>>
    <<set _randomValue to random(1, 100)>>
    <<if _randomValue <= _chanceSuccess>>
        <<include "rescueSuccess">>
    <<else>>
        <<include "rescuePossessed">>
    <</if>>
<<else>>
<<include "rescuePossessed">>
<</if>>
<<set $rescueQuestCD to 1>>



