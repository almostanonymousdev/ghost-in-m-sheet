{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Story",
      "type": "shell",
      "command": "./build.sh",
      "windows": {
        "command": "build.bat"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Build the Twee/Twine story into HTML"
    },
    {
      "label": "Open in Browser",
      "type": "shell",
      "command": "./start.sh",
      "windows": {
        "command": "start.bat"
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Build the story and open ghost-in-msheet.html in the default browser"
    },
    {
      "label": "Open with Assets in Browser",
      "type": "shell",
      "command": "./start.sh",
      "args": ["assets"],
      "windows": {
        "command": "start.bat",
        "args": ["assets"]
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Build with the real assets folder and open ghost-in-msheet.html in the default browser"
    },
    {
      "label": "Debug in Browser",
      "type": "shell",
      "command": "./start.sh",
      "args": ["debug"],
      "windows": {
        "command": "start.bat",
        "args": ["debug"]
      },
      "group": "test",
      "problemMatcher": [],
      "detail": "Build with placeholder assets and open ghost-in-msheet.html with SugarCube debug mode"
    },
    {
      "label": "Clean Build Artifacts",
      "type": "shell",
      "command": "rm",
      "args": ["-f", "ghost-in-msheet.html"],
      "windows": {
        "command": "del",
        "args": ["/q", "ghost-in-msheet.html"]
      },
      "group": "none",
      "problemMatcher": [],
      "detail": "Remove the generated HTML file"
    },
    {
      "label": "Rebuild Story",
      "type": "shell",
      "command": "./build.sh",
      "windows": {
        "command": "build.bat"
      },
      "dependsOn": "Clean Build Artifacts",
      "group": "build",
      "problemMatcher": [],
      "detail": "Clean and rebuild the story"
    }
  ]
}
