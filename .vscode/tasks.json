{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Twee Lint (watch)",
      "type": "shell",
      "command": "python3",
      "args": ["check_format.py", "--vscode", "--watch"],
      "isBackground": true,
      "runOptions": {
        "runOn": "folderOpen"
      },
      "group": "none",
      "presentation": {
        "reveal": "never",
        "echo": false,
        "panel": "dedicated",
        "close": true
      },
      "problemMatcher": {
        "owner": "twee-lint",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+): (warning) (TW\\d+): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^>>> twee-lint start$",
          "endsPattern": "^>>> twee-lint end$"
        }
      },
      "detail": "Background Twee formatting linter — shows warnings in Problems panel"
    },
    {
      "label": "Twee Lint (all files)",
      "type": "shell",
      "command": "python3",
      "args": ["check_format.py", "--vscode"],
      "group": "none",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": {
        "owner": "twee-lint-once",
        "fileLocation": ["relative", "${workspaceFolder}"],
        "pattern": {
          "regexp": "^(.+):(\\d+):(\\d+): (warning) (TW\\d+): (.+)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "code": 5,
          "message": 6
        }
      },
      "detail": "Run Twee formatting linter once on all .tw files"
    },
    {
      "label": "Build Story",
      "type": "shell",
      "command": "./build.sh",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [],
      "detail": "Build the Twee/Twine story into HTML"
    },
    {
      "label": "Open in Browser",
      "type": "shell",
      "command": "./start.sh",
      "group": "test",
      "problemMatcher": [],
      "detail": "Build the story and open ghost-in-msheet.html in the default browser"
    },
    {
      "label": "Open with Assets in Browser",
      "type": "shell",
      "command": "./start.sh",
      "args": ["assets"],
      "group": "test",
      "problemMatcher": [],
      "detail": "Build with the real assets folder and open ghost-in-msheet.html in the default browser"
    },
    {
      "label": "Debug in Browser",
      "type": "shell",
      "command": "./start.sh",
      "args": ["debug"],
      "group": "test",
      "problemMatcher": [],
      "detail": "Build with placeholder assets and open ghost-in-msheet.html with SugarCube debug mode"
    },
    {
      "label": "Clean Build Artifacts",
      "type": "shell",
      "command": "rm",
      "args": ["-f", "ghost-in-msheet.html"],
      "group": "none",
      "problemMatcher": [],
      "detail": "Remove the generated HTML file"
    },
    {
      "label": "Rebuild Story",
      "type": "shell",
      "command": "./build.sh",
      "dependsOn": "Clean Build Artifacts",
      "group": "build",
      "problemMatcher": [],
      "detail": "Clean and rebuild the story"
    }
  ]
}
